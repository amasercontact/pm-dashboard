                                <div class="relative w-20 h-20 mx-auto mb-2">
                                    <svg class="w-20 h-20 transform -rotate-90">
                                        <circle cx="40" cy="40" r="35" stroke="#374151" stroke-width="8" fill="none"/>
                                        <circle cx="40" cy="40" r="35"
