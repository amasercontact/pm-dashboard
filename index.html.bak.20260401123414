    <!-- External Scripts (Supabase) -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.39.0/dist/umd/supabase.js"></script>
    <script src="supabase.js"></script>

    <!-- Full Application Script -->
    <script>
        // ==================== STATE MANAGEMENT ====================
        const state = {
            currentUser: null,
            projects: [],
            tasks: [],
            activities: [],
            files: [],
            categories: [],
            currentView: 'projects',
            currentProjectId: null,
            currentTaskId: null,
            isEditMode: false,
            authMode: 'signin',
            calendar: null,
            theme: localStorage.getItem('theme') || 'dark'
        };

        // ==================== UTILITY FUNCTIONS ====================
        function generateId() {
            return Date.now().toString(36) + Math.random().toString(36).substr(2);
        }

        function formatDate(dateString) {
            if (!dateString) return 'No date';
            const date = new Date(dateString);
            return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        }

        function formatDateTime(dateString) {
            if (!dateString) return 'No date';
            const date = new Date(dateString);
            return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' });
        }

        function getPriorityClass(priority) {
            return `priority-${priority}`;
        }

        function getPriorityBadge(priority) {
            const colors = {
                critical: 'bg-red-500',
                high: 'bg-orange-500',
                medium: 'bg-yellow-500',
                low: 'bg-green-500'
            };
            return `<span class="px-2 py-1 rounded text-xs font-medium ${colors[priority]}">${priority.charAt(0).toUpperCase() + priority.slice(1)}</span>`;
        }

        function getStatusBadge(status) {
            const statusConfig = {
                'active': { bg: 'bg-green-500', text: 'Active' },
                'on-hold': { bg: 'bg-orange-500', text: 'On Hold' },
                'completed': { bg: 'bg-gray-500', text: 'Completed' },
                'cancelled': { bg: 'bg-red-500', text: 'Cancelled' },
                'todo': { bg: 'bg-blue-500', text: 'To Do' },
                'in-progress': { bg: 'bg-yellow-500', text: 'In Progress' },
                'review': { bg: 'bg-purple-500', text: 'Review' },
                'done': { bg: 'bg-green-500', text: 'Done' }
            };
            const config = statusConfig[status] || { bg: 'bg-gray-500', text: status };
            return `<span class="px-2 py-1 rounded text-xs font-medium ${config.bg}">${config.text}</span>`;
        }

        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            const colors = {
                success: 'bg-green-500',
                error: 'bg-red-500',
                warning: 'bg-yellow-500',
                info: 'bg-blue-500'
            };
            const icons = {
                success: 'fa-check-circle',
                error: 'fa-exclamation-circle',
                warning: 'fa-exclamation-triangle',
                info: 'fa-info-circle'
            };
            toast.className = `toast ${colors[type]} px-6 py-3 rounded-lg shadow-lg flex items-center space-x-3 animate-slideIn`;
            toast.innerHTML = `
                <i class="fas ${icons[type]}"></i>
                <span>${message}</span>
            `;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        // ==================== LOCAL STORAGE ====================
        function saveToLocalStorage() {
            if (state.currentUser) {
                localStorage.setItem(`pm_user_${state.currentUser.email}`, JSON.stringify({
                    projects: state.projects,
                    tasks: state.tasks,
                    activities: state.activities,
                    files: state.files
                }));
            }
        }

        function loadFromLocalStorage() {
            if (state.currentUser) {
                const data = localStorage.getItem(`pm_user_${state.currentUser.email}`);
                if (data) {
                    const parsed = JSON.parse(data);
                    state.projects = parsed.projects || [];
                    state.tasks = parsed.tasks || [];
                    state.activities = parsed.activities || [];
                    state.files = parsed.files || [];
                }
            }
        }

        // ==================== AUTHENTICATION ====================
        function initAuth() {
            const savedUser = localStorage.getItem('pm_current_user');
            if (savedUser) {
                state.currentUser = JSON.parse(savedUser);
                showMainDashboard();
            } else {
                showLoginScreen();
            }
        }

        function showLoginScreen() {
            document.getElementById('loginScreen').classList.remove('hidden');
            document.getElementById('mainDashboard').classList.add('hidden');
        }

        async function showMainDashboard() {
            document.getElementById('loginScreen').classList.add('hidden');
            document.getElementById('mainDashboard').classList.remove('hidden');
            document.getElementById('userName').textContent = state.currentUser.name;
            document.getElementById('userAvatar').textContent = state.currentUser.name.charAt(0).toUpperCase();
            document.getElementById('dropdownUserName').textContent = state.currentUser.name;
            document.getElementById('dropdownUserEmail').textContent = state.currentUser.email;

            // Load local data first
            loadFromLocalStorage();

            // Then try to sync with Supabase (if available)
            await syncWithSupabase();

            showView('projects');
            updateStats();
        }

        // Sync local data with Supabase
        async function syncWithSupabase() {
            console.log('Starting Supabase sync...');

            // Wait for SupabaseDB to be available with proper retry
            let retries = 0;
            const maxRetries = 50;
            while ((typeof SupabaseDB === 'undefined' || typeof SupabaseDB.loadProjects !== 'function') && retries < maxRetries) {
                await new Promise(r => setTimeout(r, 100));
                retries++;
            }

            if (typeof SupabaseDB === 'undefined' || typeof SupabaseDB.loadProjects !== 'function') {
                console.error('SupabaseDB not available after retries');
                // Fall back to localStorage only if Supabase is unavailable
                loadFromLocalStorage();
                return;
            }

            try {
                // ALWAYS fetch fresh data from Supabase - don't rely on localStorage cache
                console.log('Fetching fresh projects from Supabase...');
                const projects = await SupabaseDB.loadProjectsFresh();
                state.projects = projects || [];
                console.log('Set state.projects to', state.projects.length, 'projects');

                // Also fetch fresh tasks
                console.log('Fetching fresh tasks from Supabase...');
                const tasks = await SupabaseDB.loadTasksFresh();
                if (tasks && Array.isArray(tasks)) {
                    state.tasks = tasks;
                    console.log('Set state.tasks to', state.tasks.length, 'tasks');
                }

                // NEW: Fetch fresh files from database (fixes localStorage-only issue)
                console.log('Fetching fresh files from Supabase database...');
                if (typeof SupabaseDBFile !== 'undefined' && SupabaseDBFile.loadAllFiles) {
                    try {
                        const filesResult = await SupabaseDBFile.loadAllFiles();
                        if (filesResult.error) {
                            console.warn('Failed to load files from DB:', filesResult.error);
                            // Fall back to localStorage for files
                            const localData = localStorage.getItem(`pm_user_${state.currentUser.email}`);
                            if (localData) {
                                const parsed = JSON.parse(localData);
                                state.files = parsed.files || [];
                            }
                        } else {
                            state.files = filesResult.files || [];
                            console.log('Set state.files to', state.files.length, 'files from database');
                        }
                    } catch (e) {
                        console.warn('Exception loading files from DB, using localStorage:', e);
                        const localData = localStorage.getItem(`pm_user_${state.currentUser.email}`);
                        if (localData) {
                            const parsed = JSON.parse(localData);
                            state.files = parsed.files || [];
                        }
                    }
                } else {
                    console.warn('SupabaseDBFile not available, using localStorage for files');
                    const localData = localStorage.getItem(`pm_user_${state.currentUser.email}`);
                    if (localData) {
                        const parsed = JSON.parse(localData);
                        state.files = parsed.files || [];
                    }
                }

                // Load categories - delegate to populateCategorySelects which handles loading AND DOM update
                // Use forceReload=true to ensure we ALWAYS fetch fresh data from DB on sync
                console.log('Loading categories via populateCategorySelects(true)...');
                if (typeof SupabaseCategories !== 'undefined' && SupabaseCategories.loadAll) {
                    try {
                        await populateCategorySelects(true);
                    } catch (e) {
                        console.warn('Exception loading categories:', e);
                        // Fallback: try without forceReload in case forceReload itself had an issue
                        try {
                            await populateCategorySelects(false);
                        } catch (e2) {
                            console.warn('Fallback category load also failed:', e2);
                        }
                    }
                } else {
                    // SupabaseCategories not ready yet - wait and retry
                    console.warn('SupabaseCategories not available, waiting and retrying...');
                    let catRetries = 0;
                    const maxCatRetries = 20; // 20 * 200ms = 4 seconds max wait
                    while ((typeof SupabaseCategories === 'undefined' || !SupabaseCategories.loadAll) && catRetries < maxCatRetries) {
                        await new Promise(r => setTimeout(r, 200));
                        catRetries++;
                    }
                    if (SupabaseCategories && SupabaseCategories.loadAll) {
                        console.log('SupabaseCategories became available after', catRetries, 'retries');
                        try {
                            await populateCategorySelects(true);
                        } catch (e) {
                            console.warn('Exception loading categories after wait:', e);
                        }
                    } else {
                        console.error('SupabaseCategories never became available, categories may not load');
                    }
                }

                // Save to localStorage as backup
                saveToLocalStorage();

                // Update UI
                updateStats();
                if (state.currentView === 'dashboard') {
                    updateDashboard();
                } else if (state.currentView === 'projects') {
                    renderProjects();
                } else if (state.currentView === 'tasks') {
                    renderTasks();
                }

                console.log('Synced with Supabase:', {
                    projects: state.projects.length,
                    tasks: state.tasks.length
                });
            } catch (error) {
                console.error('Supabase sync error:', error);
                showToast('Supabase sync failed: ' + error.message + ' - using local data', 'error');
                // Fall back to localStorage on error
                loadFromLocalStorage();
            }
        }

        // Force refresh from Supabase (for manual refresh button)
        async function refreshFromSupabase() {
            console.log('Manual refresh triggered...');
            showToast('Refreshing data from server...', 'info');
            await syncWithSupabase();
            showToast('Data refreshed!', 'success');
        }

        function handleAuth(e) {
            e.preventDefault();
            const email = document.getElementById('authEmail').value;
            const password = document.getElementById('authPassword').value;

            if (password.length < 6) {
                showToast('Password must be at least 6 characters', 'error');
                return;
            }

            if (state.authMode === 'signup') {
                const confirmPassword = document.getElementById('authConfirmPassword').value;
                const name = document.getElementById('authName').value;

                if (password !== confirmPassword) {
                    showToast('Passwords do not match', 'error');
                    return;
                }

                if (!name) {
                    showToast('Please enter your name', 'error');
                    return;
                }

                // Check if user exists
                const existingUser = localStorage.getItem(`pm_user_${email}`);
                if (existingUser) {
                    showToast('An account with this email already exists', 'error');
                    return;
                }

                // Create new user
                state.currentUser = {
                    id: generateId(),
                    email: email,
                    name: name,
                    createdAt: new Date().toISOString()
                };
                localStorage.setItem('pm_current_user', JSON.stringify(state.currentUser));
                state.projects = [];
                state.tasks = [];
                state.activities = [];
                state.files = [];
                showToast('Account created successfully!', 'success');
                showMainDashboard();
            } else {
                // Sign in
                const existingUser = localStorage.getItem(`pm_user_${email}`);
                if (existingUser) {
                    state.currentUser = JSON.parse(existingUser);
                    localStorage.setItem('pm_current_user', JSON.stringify(state.currentUser));
                    showMainDashboard();
                    showToast(`Welcome back, ${state.currentUser.name}!`, 'success');
                } else {
                    // Auto-create account for demo
                    state.currentUser = {
                        id: generateId(),
                        email: email,
                        name: email.split('@')[0],
                        createdAt: new Date().toISOString()
                    };
                    localStorage.setItem('pm_current_user', JSON.stringify(state.currentUser));
                    state.projects = [];
                    state.tasks = [];
                    state.activities = [];
                    state.files = [];
                    showMainDashboard();
                    showToast('Account created automatically', 'success');
                }
            }
        }

        function toggleAuthMode() {
            state.authMode = state.authMode === 'signin' ? 'signup' : 'signin';
            const title = document.getElementById('authTitle');
            const submitBtn = document.getElementById('authSubmitBtn');
            const toggleText = document.getElementById('toggleAuthText');
            const toggleBtn = document.getElementById('toggleAuthBtn');
            const confirmGroup = document.getElementById('confirmPasswordGroup');
            const usernameGroup = document.getElementById('usernameGroup');

            if (state.authMode === 'signup') {
                title.textContent = 'Create Account';
                submitBtn.textContent = 'Sign Up';
                toggleText.textContent = 'Already have an account?';
                toggleBtn.textContent = 'Sign In';
                confirmGroup.classList.remove('hidden');
                usernameGroup.classList.remove('hidden');
            } else {
                title.textContent = 'Sign In';
                submitBtn.textContent = 'Sign In';
                toggleText.textContent = "Don't have an account?";
                toggleBtn.textContent = 'Sign Up';
                confirmGroup.classList.add('hidden');
                usernameGroup.classList.add('hidden');
            }
        }

        function logout() {
            state.currentUser = null;
            state.projects = [];
            state.tasks = [];
            state.activities = [];
            state.files = [];
            localStorage.removeItem('pm_current_user');
            showLoginScreen();
            showToast('Logged out successfully', 'info');
        }

        // ==================== THEME ====================
        function initTheme() {
            if (state.theme === 'light') {
                document.documentElement.classList.remove('dark');
                document.documentElement.classList.add('light');
                document.querySelector('.dark-icon').classList.add('hidden');
                document.querySelector('.light-icon').classList.remove('hidden');
            }
        }

        function toggleTheme() {
            state.theme = state.theme === 'dark' ? 'light' : 'dark';
            localStorage.setItem('theme', state.theme);
            if (state.theme === 'light') {
                document.documentElement.classList.remove('dark');
                document.documentElement.classList.add('light');
                document.querySelector('.dark-icon').classList.add('hidden');
                document.querySelector('.light-icon').classList.remove('hidden');
            } else {
                document.documentElement.classList.remove('light');
                document.documentElement.classList.add('dark');
                document.querySelector('.dark-icon').classList.remove('hidden');
                document.querySelector('.light-icon').classList.add('hidden');
            }
            if (state.calendar) {
                renderCalendar();
            }
        }

        // ==================== NAVIGATION ====================
        function showView(viewName, projectId = null) {
            state.currentView = viewName;
            if (projectId) state.currentProjectId = projectId;

            // Update nav tabs
            document.querySelectorAll('.nav-tab').forEach(tab => {
                tab.classList.remove('active', 'bg-primary', 'text-white');
                if (tab.dataset.view === viewName) {
                    tab.classList.add('active', 'bg-primary', 'text-white');
                }
            });

            // Hide all views
            document.querySelectorAll('.view-section').forEach(section => {
                section.classList.add('hidden');
            });

            // Show selected view
            switch(viewName) {
                case 'projects':
                    document.getElementById('projectsView').classList.remove('hidden');
                    renderProjects();
                    break;
                case 'tasks':
                    document.getElementById('tasksView').classList.remove('hidden');
                    renderTasks();
                    break;
                case 'calendar':
                    document.getElementById('calendarView').classList.remove('hidden');
                    renderCalendar();
                    break;
                case 'dashboard':
                    document.getElementById('dashboardView').classList.remove('hidden');
                    updateDashboard();
                    break;
                case 'project-detail':
                    document.getElementById('projectDetailView').classList.remove('hidden');
                    renderProjectDetail();
                    break;
            }

            // Close mobile nav
            document.getElementById('mobileNav').classList.remove('open');
            document.getElementById('mobileNavOverlay').classList.add('hidden');
        }

        // ==================== PROJECTS ====================
        function renderProjects() {
            const grid = document.getElementById('projectsGrid');
            const emptyState = document.getElementById('projectsEmptyState');
            const filter = document.getElementById('projectFilter').value;

            // Ensure category dropdown is populated before filtering
            // This fixes the issue where categories weren't loaded if syncWithSupabase failed
            const categorySelect = document.getElementById('categoryFilter');
            if (categorySelect && categorySelect.options.length <= 1) {
                console.log('Category dropdown empty, populating before render...');
                populateCategorySelects();
            }

            const categoryFilter = document.getElementById('categoryFilter').value;

            let filteredProjects = state.projects;
            if (filter !== 'all') {
                filteredProjects = filteredProjects.filter(p => p.status === filter);
            }
            if (categoryFilter !== 'all') {
                filteredProjects = filteredProjects.filter(p => p.category_id === categoryFilter);
            }

            if (filteredProjects.length === 0) {
                grid.innerHTML = '';
                emptyState.classList.remove('hidden');
                return;
            }

            emptyState.classList.add('hidden');
            grid.innerHTML = filteredProjects.map(project => {
                const tasks = state.tasks.filter(t => t.project_id === project.id);
                const completedTasks = tasks.filter(t => t.status === 'done').length;
                const progress = tasks.length > 0 ? Math.round((completedTasks / tasks.length) * 100) : 0;

                return `
                    <div class="project-card bg-gray-800/50 rounded-xl p-6 border border-gray-700 cursor-pointer ${getPriorityClass(project.priority)}"
                         onclick="openProjectDetail('${project.id}')">
                        <div class="flex items-start justify-between mb-4">
                            <div class="w-10 h-10 rounded-lg" style="background-color: ${project.color || '#4f46e5'}"></div>
                            <div class="flex items-center space-x-2">
                                ${getStatusBadge(project.status)}
                                <button onclick="deleteProject('${project.id}', event)" class="p-1.5 hover:bg-red-500/20 rounded-lg transition text-gray-400 hover:text-red-400" title="Delete Project">
                                    <i class="fas fa-trash text-sm"></i>
                                </button>
                            </div>
                        </div>
                        <h3 class="text-lg font-semibold mb-2 truncate">${project.name}</h3>
                        <p class="text-gray-400 text-sm mb-4 line-clamp-2">${project.description || 'No description'}</p>
                        <div class="mb-4">
                            <div class="flex justify-between text-xs text-gray-400 mb-1">
                                <span>Progress</span>
                                <span>${progress}%</span>
                            </div>
                            <div class="h-2 bg-gray-700 rounded-full overflow-hidden">
                                <div class="h-full bg-primary rounded-full transition-all" style="width: ${progress}%"></div>
                            </div>
                        </div>
                        <div class="flex items-center justify-between text-sm text-gray-400">
                            <span><i class="fas fa-tasks mr-1"></i>${tasks.length}</span>
                            <span><i class="fas fa-check mr-1"></i>${completedTasks}</span>
                            <span>${formatDate(project.dueDate)}</span>
                        </div>
