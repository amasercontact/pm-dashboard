            document.getElementById('statTasks').textContent = state.tasks.length;
            document.getElementById('statCompleted').textContent = state.tasks.filter(t => t.status === 'done').length;
            document.getElementById('statPending').textContent = state.tasks.filter(t => t.status !== 'done').length;
        }

