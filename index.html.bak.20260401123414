        }

        function closeTaskDetailModal() {
            document.getElementById('taskDetailModal').classList.add('hidden');
        }

        async function toggleTaskStatus(taskId) {
            const task = state.tasks.find(t => t.id === taskId);
            if (task) {
                const newStatus = task.status === 'done' ? 'todo' : 'done';
                task.status = newStatus;
                task.updatedAt = new Date().toISOString();

                if (newStatus === 'done') {
                    logActivity('task_completed', taskId, `Completed task "${task.title}"`);
                }

                saveToLocalStorage();

                // CRITICAL FIX: Also persist to Supabase database
                if (typeof SupabaseDB !== 'undefined' && SupabaseDB.updateTask) {
                    const dbResult = await SupabaseDB.updateTask(taskId, { status: newStatus });
                    if (dbResult && dbResult.error) {
                        console.error('Failed to persist task status to DB:', dbResult.error);
                    } else {
                        console.log('Task status persisted to Supabase:', taskId, '->', newStatus);
                    }
                }

                if (state.currentView === 'tasks') {
                    renderTasks();
                } else if (state.currentView === 'project-detail') {
                    renderProjectTasks();
                    updateProjectStats();
                }
                updateStats();
            }
        }

        async function toggleSubtask(taskId, subtaskId) {
            const task = state.tasks.find(t => t.id === taskId);
            if (task && task.subtasks) {
                const subtask = task.subtasks.find(s => s.id === subtaskId);
                if (subtask) {
                    subtask.completed = !subtask.completed;
                    task.updatedAt = new Date().toISOString();
                    saveToLocalStorage();

                    // CRITICAL FIX: Persist subtask change to Supabase
                    if (typeof SupabaseDB !== 'undefined' && SupabaseDB.updateTask) {
                        const dbResult = await SupabaseDB.updateTask(taskId, { subtasks: task.subtasks });
                        if (dbResult && dbResult.error) {
                            console.error('Failed to persist subtask to DB:', dbResult.error);
                        }
                    }

                    openTaskDetail(taskId);

                    if (state.currentView === 'project-detail') {
                        renderProjectTasks();
                    }
                }
            }
        }

        async function addDetailTaskComment() {
            const input = document.getElementById('taskDetailNewComment');
            const text = input.value.trim();
            if (!text) return;

            const task = state.tasks.find(t => t.id === state.currentTaskId);
            if (task) {
                if (!task.comments) task.comments = [];
                task.comments.push({
                    text,
                    timestamp: new Date().toISOString()
                });
                task.updatedAt = new Date().toISOString();
                saveToLocalStorage();

                // CRITICAL FIX: Persist comment to Supabase
                if (typeof SupabaseDB !== 'undefined' && SupabaseDB.updateTask) {
                    const dbResult = await SupabaseDB.updateTask(state.currentTaskId, { comments: task.comments });
                    if (dbResult && dbResult.error) {
                        console.error('Failed to persist comment to DB:', dbResult.error);
                    }
                }

                openTaskDetail(state.currentTaskId);
            }
        }

        function deleteCurrentTask() {
            const task = state.tasks.find(t => t.id === state.currentTaskId);
            showConfirmDialog(
                'Delete Task',
                `Are you sure you want to delete "${task?.title}"? This will also delete all attached files.`,
                async () => {
                    // Delete task files from storage (cascading cleanup)
                    try {
                        if (window.SupabaseStorage && window.SupabaseStorage.deleteTaskFiles) {
                            await window.SupabaseStorage.deleteTaskFiles(task.project_id, state.currentTaskId);
                        }
                    } catch (e) {
                        console.error('Error deleting task files from storage:', e);
                    }

                    // NEW: Also delete task file metadata from database
                    try {
                        if (typeof SupabaseDBFile !== 'undefined' && SupabaseDBFile.deleteTaskFileMetadata) {
                            await SupabaseDBFile.deleteTaskFileMetadata(state.currentTaskId);
                        }
                    } catch (e) {
                        console.warn('Error deleting task file metadata from DB:', e);
                    }

                    // Remove task files from state
                    const taskFileIds = state.files.filter(f => f.task_id === state.currentTaskId).map(f => f.id);
                    state.files = state.files.filter(f => f.task_id !== state.currentTaskId);

                    logActivity('task_deleted', state.currentTaskId, `Deleted task "${task?.title}"`);
                    state.tasks = state.tasks.filter(t => t.id !== state.currentTaskId);
                    saveToLocalStorage();
                    closeTaskDetailModal();

                    if (state.currentView === 'tasks') {
                        renderTasks();
                    } else if (state.currentView === 'project-detail') {
                        renderProjectTasks();
                        updateProjectStats();
                    }
                    updateStats();
                    showToast('Task deleted', 'success');
                }
            );
        }

        function updateProjectStats() {
            const tasks = state.tasks.filter(t => t.project_id === state.currentProjectId);
            const completed = tasks.filter(t => t.status === 'done').length;
            const inProgress = tasks.filter(t => t.status === 'in-progress').length;
            const progress = tasks.length > 0 ? Math.round((completed / tasks.length) * 100) : 0;

            document.getElementById('projectDetailTasks').textContent = tasks.length;
            document.getElementById('projectDetailCompleted').textContent = completed;
            document.getElementById('projectDetailInProgress').textContent = inProgress;
            document.getElementById('projectDetailProgress').textContent = `${progress}%`;
        }

        // ==================== CALENDAR ====================
        function renderCalendar() {
            const calendarEl = document.getElementById('calendar');

            if (state.calendar) {
                state.calendar.destroy();
            }

            // Update project filter
            const filter = document.getElementById('calendarProjectFilter');
            filter.innerHTML = '<option value="all">All Projects</option>' +
                state.projects.map(p => `<option value="${p.id}">${p.name}</option>`).join('');

            const selectedProject = filter.value;

            let tasksToShow = state.tasks;

            if (selectedProject !== 'all') {
                tasksToShow = tasksToShow.filter(t => t.project_id === selectedProject);
            }

            const events = tasksToShow
                .filter(t => t.dueDate)
                .map(task => {
                    const project = state.projects.find(p => p.id === task.project_id);
                    // Build title with time based on project + day of week
                    let displayTitle = task.title;
                    // Get day number - parse date parts to avoid timezone issues (0=Sunday, 1=Monday, 2=Tuesday, 3=Wednesday, 4=Thursday, 5=Friday, 6=Saturday)
                    const parts = task.dueDate.split('-');
                    const dayNum = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2])).getDay();

                    const pid = task.project_id;

                    // Python Learning (24f723f5...): Tue=5-7pm, Sat=8am-12pm
                    if (pid === '24f723f5-4d47-46a9-9232-991e1ebf841a') {
                        if (dayNum === 2) displayTitle = '5-7pm CT | ' + task.title;
                        else if (dayNum === 6) displayTitle = '8am-12pm CT | ' + task.title;
                    }
                    // MCP Research (fddbcfdf...): Thu=5-7pm, Sun=8am-12pm
                    else if (pid === 'fddbcfdf-62ff-4b93-b1d5-924694909247') {
                        if (dayNum === 4) displayTitle = '5-7pm CT | ' + task.title;
                        else if (dayNum === 0) displayTitle = '8am-12pm CT | ' + task.title;
                    }
                    // Jose Frias (74ede6ac...): 2pm CT
                    else if (pid === '74ede6ac-9d9e-446b-ab0d-658629383ac0') {
                        displayTitle = '2pm CT | ' + task.title;
                    }
                    // Social Media (5bcccc6a...): 8pm CT
                    else if (pid === '5bcccc6a-61b5-45e0-ab8b-8656c1e038f7') {
                        displayTitle = '8pm CT | ' + task.title;
                    }
                    // PM Dashboard (68b3ec50...): 8pm CT
                    else if (pid === '68b3ec50-61a6-4e38-b23e-f11f5c1b9a2d') {
                        displayTitle = '8pm CT | ' + task.title;
                    }
                    // Fencing (f883dc3f...): 3am CT
                    else if (pid === 'f883dc3f-bb53-47c7-876b-3f55f23b8683') {
                        displayTitle = '3am CT | ' + task.title;
                    }
                    // Aquaponics (f1bb742e...): 12pm CT
                    else if (pid === 'f1bb742e-de0b-4825-8906-3de082204ee0') {
                        displayTitle = '12pm CT | ' + task.title;
                    }

                    return {
                        id: task.id,
                        title: displayTitle,
                        start: task.dueDate,
                        backgroundColor: project?.color || '#4f46e5',
                        borderColor: project?.color || '#4f46e5',
                        extendedProps: {
                            projectId: task.project_id,
                            status: task.status
                        }
                    };
                });

            state.calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,listWeek'
                },
                events: events,
                eventClick: function(info) {
                    openTaskDetail(info.event.id);
                },
                height: 'auto',
                themeSystem: state.theme === 'dark' ? 'dark' : 'standard'
            });

            state.calendar.render();
