        async function handleProjectSubmit(e) {
            e.preventDefault();

            const id = document.getElementById('projectId').value || generateId();
            const isUpdate = !!document.getElementById('projectId').value;
            const teamMembersValue = document.getElementById('projectTeamMembers').value;
            const teamMembers = teamMembersValue ? teamMembersValue.split(',').map(m => m.trim()).filter(m => m) : [];

            const projectData = {
                id,
                name: document.getElementById('projectName').value,
                description: document.getElementById('projectDescription').value,
                status: document.getElementById('projectStatus').value,
                priority: document.getElementById('projectPriority').value,
                category_id: document.getElementById('projectCategory').value || null,
                dueDate: document.getElementById('projectDueDate').value,
                color: document.getElementById('projectColor').value,
                teamMembers,
                notes: document.getElementById('projectNotes').value,
                userId: state.currentUser.id,
                createdAt: new Date().toISOString(),
                updatedAt: new Date().toISOString()
            };

            if (isUpdate) {
                // Update existing
                const index = state.projects.findIndex(p => p.id === id);
                if (index !== -1) {
                    projectData.createdAt = state.projects[index].createdAt;
                    state.projects[index] = projectData;
                    logActivity('project_updated', id, `Updated project "${projectData.name}"`);
                    showToast('Project updated successfully', 'success');
                }
                // CRITICAL FIX: Persist to Supabase database
                if (typeof SupabaseDB !== 'undefined' && SupabaseDB.updateProject) {
                    const updatePayload = {
                        name: projectData.name,
                        description: projectData.description,
                        status: projectData.status,
                        priority: projectData.priority,
                        category_id: projectData.category_id,
                        due_date: projectData.dueDate,
                        color: projectData.color,
                        team_members: projectData.teamMembers,
                        notes: projectData.notes
                    };
                    console.log('[DEBUG handleProjectSubmit] category_id from form:', projectData.category_id);
                    console.log('[DEBUG handleProjectSubmit] Full update payload:', JSON.stringify(updatePayload, null, 2));
                    const dbResult = await SupabaseDB.updateProject(id, updatePayload);
                    console.log('[DEBUG handleProjectSubmit] DB update result:', dbResult);
                    if (dbResult && dbResult.error) {
                        console.error('Failed to persist project update to DB:', dbResult.error);
                    } else {
                        console.log('Project update persisted to Supabase:', id, 'category_id:', projectData.category_id);
                    }
                }
            } else {
                // Create new
                state.projects.unshift(projectData);
                logActivity('project_created', id, `Created project "${projectData.name}"`);
                showToast('Project created successfully', 'success');
                // CRITICAL FIX: Persist to Supabase database
                if (typeof SupabaseDB !== 'undefined' && SupabaseDB.saveProject) {
                    console.log('[DEBUG handleProjectSubmit] CREATE - category_id being saved:', projectData.category_id);
                    const dbResult = await SupabaseDB.saveProject(projectData);
                    console.log('[DEBUG handleProjectSubmit] CREATE - DB result:', dbResult);
                    if (dbResult && dbResult.error) {
                        console.error('Failed to persist new project to DB:', dbResult.error);
                    } else {
                        console.log('New project persisted to Supabase:', id, 'category_id:', projectData.category_id);
                    }
                }
            }

            saveToLocalStorage();
            closeProjectModal();

            if (state.currentView === 'project-detail') {
                renderProjectDetail();
            } else {
                renderProjects();
            }
            updateStats();
        }

        function deleteCurrentProject() {
            showConfirmDialog(
                'Delete Project',
                'Are you sure you want to delete this project? This will also delete all associated tasks and files.',
                async () => {
                    const project = state.projects.find(p => p.id === state.currentProjectId);
                    logActivity('project_deleted', state.currentProjectId, `Deleted project "${project?.name}"`);

                    // Delete from Supabase first
                    try {
                        if (typeof SupabaseDB !== 'undefined' && SupabaseDB.deleteProject) {
                            await SupabaseDB.deleteProject(state.currentProjectId);
                        }
                    } catch (e) {
                        console.error('Supabase delete error:', e);
                    }

                    // Also delete associated tasks from Supabase
                    try {
                        if (typeof SupabaseDB !== 'undefined' && SupabaseDB.deleteTask) {
                            const tasksToDelete = state.tasks.filter(t => t.project_id === state.currentProjectId);
                            for (const task of tasksToDelete) {
                                await SupabaseDB.deleteTask(task.id);
                            }
                        }
                    } catch (e) {
                        console.error('Supabase delete tasks error:', e);
                    }

                    state.projects = state.projects.filter(p => p.id !== state.currentProjectId);
                    state.tasks = state.tasks.filter(t => t.project_id !== state.currentProjectId);
                    state.files = state.files.filter(f => f.project_id !== state.currentProjectId);

                    saveToLocalStorage();
                    showToast('Project deleted', 'success');
                    showView('projects');
                }
            );
        }

