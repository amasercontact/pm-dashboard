        function addTaskComment() {
            const input = document.getElementById('newTaskComment');
            const text = input.value.trim();
            if (!text) return;

            const commentsContainer = document.getElementById('taskComments');
            const commentHtml = `
                <div class="bg-gray-700/50 rounded-lg p-2 text-sm animate-fadeIn">
                    <p>${text}</p>
