        // ==================== FILE HANDLING ====================
        function initFileDropZone() {
            const dropZone = document.getElementById('fileDropZone');
            const fileInput = document.getElementById('fileInput');

            if (!dropZone) return;

            dropZone.addEventListener('click', () => fileInput.click());

            dropZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                dropZone.classList.add('dragover');
            });

            dropZone.addEventListener('dragleave', () => {
                dropZone.classList.remove('dragover');
            });

            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropZone.classList.remove('dragover');
                handleFileUpload(e.dataTransfer.files);
            });

            fileInput.addEventListener('change', (e) => {
                handleFileUpload(e.target.files);
            });
        }

        async function handleFileUpload(fileList, taskId = null) {
            // Ensure SupabaseStorage is available
            if (typeof window.SupabaseStorage === 'undefined' || typeof window.SupabaseStorage.uploadFile !== 'function') {
                console.error('SupabaseStorage not available, waiting...');
                showToast('Storage system not ready. Please try again in a moment.', 'error');
                return;
            }

            // Ensure we have a current project
            if (!state.currentProjectId) {
                console.error('No project selected for file upload');
                showToast('Please open a project before uploading files', 'error');
                return;
            }

            for (const file of Array.from(fileList)) {
                const fileId = generateId();
                let storagePath = null;
                let publicUrl = null;
                let uploadSuccess = false;

                // Try to upload to Supabase Storage
                try {
                    console.log('Uploading file:', file.name, 'to project:', state.currentProjectId, 'task:', taskId);
                    const result = await window.SupabaseStorage.uploadFile(file, state.currentProjectId, fileId, taskId);
                    console.log('Upload result:', result);

                    // Check if upload actually succeeded
                    if (result.error) {
                        console.error('Supabase upload error:', result.error);
                        showToast(`Storage upload failed: ${result.error}`, 'error');
                    } else if (!result.path || !result.publicUrl) {
                        console.error('Upload returned null path or URL:', result);
                        showToast(`Storage returned invalid response`, 'error');
                    } else {
                        storagePath = result.path;
                        publicUrl = result.publicUrl;
                        uploadSuccess = true;
                        console.log('Upload successful, path:', storagePath);
                    }
                } catch (error) {
                    console.error('Upload exception:', error);
                    showToast(`Upload failed: ${error.message}`, 'error');
                }

                // ALWAYS add file to state, even if upload failed (for local tracking)
                // Files can have both project_id AND task_id (dual-mode)
                const fileData = {
                    id: fileId,
                    project_id: state.currentProjectId,
                    task_id: taskId, // Can be null for project-level files
                    name: file.name,
                    type: file.type,
                    size: file.size,
                    storagePath: storagePath,
                    publicUrl: publicUrl,
                    uploadedAt: new Date().toISOString(),
                    uploadedBy: state.currentUser.id,
                    uploadSuccess: uploadSuccess
                };

                console.log('Adding file to state:', fileData);
                state.files.push(fileData);
                logActivity('file_uploaded', fileData.id, `Uploaded file "${file.name}"${taskId ? ' to task' : ' to project'}`);
                saveToLocalStorage();

                // NEW: Save file metadata to database for cross-browser access
                if (typeof window.SupabaseDBFile !== 'undefined' && window.SupabaseDBFile.saveFileMetadata) {
                    try {
                        const dbResult = await window.SupabaseDBFile.saveFileMetadata(fileData);
                        if (dbResult.error) {
                            console.warn('Failed to save file metadata to DB (will rely on localStorage):', dbResult.error);
                        } else {
                            console.log('File metadata saved to database:', dbResult.data);
                        }
                    } catch (e) {
                        console.warn('Exception saving file metadata to DB:', e);
                    }
                }

                // Re-render appropriate file list
                if (taskId) {
                    renderTaskDetailFiles(taskId);
                } else {
                    renderProjectFiles();
                }

                if (uploadSuccess) {
                    showToast(`Uploaded ${file.name}`, 'success');
                } else {
                    showToast(`File "${file.name}" saved locally (upload pending)`, 'warning');
                }
            }
        }

        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        async function downloadFile(fileId) {
            const file = state.files.find(f => f.id === fileId);
            if (!file) return;
            
            try {
                // Extract filename from storagePath (format: bucket/projectId/fileId/filename or bucket/projectId/tasks/taskId/fileId/filename)
                const pathParts = file.storagePath.split('/');
                const filename = pathParts[pathParts.length - 1];
                const signedUrl = await window.SupabaseStorage.getFileUrl(file.project_id, file.id, filename, 3600, file.task_id);
                window.open(signedUrl.url, '_blank');
            } catch (error) {
                showToast(`Failed to download ${file.name}: ${error.message}`, 'error');
            }
        }
        
        async function deleteFile(fileId, fromTaskDetail = false) {
            const file = state.files.find(f => f.id === fileId);
            showConfirmDialog(
                'Delete File',
                `Are you sure you want to delete "${file?.name}"?`,
                async () => {
                    try {
                        if (file.storagePath) {
                            // Extract filename from storagePath
                            const pathParts = file.storagePath.split('/');
                            const filename = pathParts[pathParts.length - 1];
                            await window.SupabaseStorage.deleteFile(file.project_id, file.id, filename, file.task_id);
                        }
                        // NEW: Also delete file metadata from database
                        if (typeof SupabaseDBFile !== 'undefined' && SupabaseDBFile.deleteFileMetadata) {
                            try {
                                await SupabaseDBFile.deleteFileMetadata(fileId);
                            } catch (e) {
                                console.warn('Failed to delete file metadata from DB:', e);
                            }
                        }
                        logActivity('file_deleted', fileId, `Deleted file "${file?.name}"`);
                        state.files = state.files.filter(f => f.id !== fileId);
                        saveToLocalStorage();
                        if (fromTaskDetail && file.task_id) {
                            renderTaskDetailFiles(file.task_id);
                        } else {
                            renderProjectFiles();
                        }
                        showToast('File deleted', 'success');
                    } catch (error) {
                        showToast(`Failed to delete ${file?.name}: ${error.message}`, 'error');
                    }
                }
            );
        }

        function exportProjectFiles() {
            const project = state.projects.find(p => p.id === state.currentProjectId);
            const projectTasks = state.tasks.filter(t => t.project_id === state.currentProjectId);
            const projectFiles = state.files.filter(f => f.project_id === state.currentProjectId);

            const exportData = {
                project,
                tasks: projectTasks,
                files: projectFiles,
                exportedAt: new Date().toISOString()
            };

            downloadJSON(exportData, `${project?.name || 'project'}-export.json`);
        }

        // ==================== IMPORT/EXPORT ====================
        function exportAllData() {
            const exportData = {
                user: state.currentUser,
                projects: state.projects,
                tasks: state.tasks,
                activities: state.activities,
                files: state.files,
                exportedAt: new Date().toISOString()
            };

            downloadJSON(exportData, `projectflow-export-${new Date().toISOString().split('T')[0]}.json`);
            showToast('Data exported successfully', 'success');
        }

        function downloadJSON(data, filename) {
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = filename;
            link.click();
            URL.revokeObjectURL(url);
        }

        function importData(file) {
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const data = JSON.parse(e.target.result);

                    if (data.projects) state.projects = data.projects;
                    if (data.tasks) state.tasks = data.tasks;
                    if (data.activities) state.activities = data.activities;
                    if (data.files) state.files = data.files;

                    saveToLocalStorage();
                    showToast('Data imported successfully', 'success');
                    renderProjects();
                    updateStats();
                } catch (error) {
                    showToast('Failed to import data: Invalid file format', 'error');
                }
            };
            reader.readAsText(file);
        }

        // ==================== CONFIRM DIALOG ====================
        function showConfirmDialog(title, message, onConfirm) {
            document.getElementById('confirmTitle').textContent = title;
            document.getElementById('confirmMessage').textContent = message;
            document.getElementById('confirmActionBtn').onclick = () => {
                onConfirm();
                closeConfirmDialog();
            };
            document.getElementById('confirmDialog').classList.remove('hidden');
        }

        function closeConfirmDialog() {
            document.getElementById('confirmDialog').classList.add('hidden');
        }

        // ==================== SEARCH ====================
        function handleGlobalSearch(query) {
            if (!query.trim()) return;

            const lowerQuery = query.toLowerCase();

            // Search projects
            const matchingProjects = state.projects.filter(p =>
                p.name.toLowerCase().includes(lowerQuery) ||
                p.description?.toLowerCase().includes(lowerQuery)
            );

            // Search tasks
            const matchingTasks = state.tasks.filter(t =>
                t.title.toLowerCase().includes(lowerQuery) ||
                t.description?.toLowerCase().includes(lowerQuery)
            );

            // Show results in a simple alert for now
            if (matchingProjects.length > 0) {
                showToast(`Found ${matchingProjects.length} matching projects`, 'info');
            } else if (matchingTasks.length > 0) {
                showToast(`Found ${matchingTasks.length} matching tasks`, 'info');
            } else {
                showToast('No results found', 'info');
            }
        }

        // ==================== EVENT LISTENERS ====================
        document.addEventListener('DOMContentLoaded', () => {
            // NOTE: initAuth() and initTheme() are called at the end of this handler
            // to ensure all functions (like populateCategorySelects) are defined first

            // Auth form
            document.getElementById('authForm').addEventListener('submit', handleAuth);
            document.getElementById('toggleAuthBtn').addEventListener('click', toggleAuthMode);
            document.getElementById('logoutBtn').addEventListener('click', logout);

            // Theme toggle
            document.getElementById('themeToggle').addEventListener('click', toggleTheme);

            // Navigation tabs
            document.querySelectorAll('.nav-tab').forEach(tab => {
                tab.addEventListener('click', () => showView(tab.dataset.view));
            });

            // Mobile navigation
            document.getElementById('mobileMenuBtn').addEventListener('click', () => {
                document.getElementById('mobileNav').classList.add('open');
                document.getElementById('mobileNavOverlay').classList.remove('hidden');
            });

            document.getElementById('closeMobileNav').addEventListener('click', () => {
                document.getElementById('mobileNav').classList.remove('open');
                document.getElementById('mobileNavOverlay').classList.add('hidden');
            });

            document.getElementById('mobileNavOverlay').addEventListener('click', () => {
                document.getElementById('mobileNav').classList.remove('open');
                document.getElementById('mobileNavOverlay').classList.add('hidden');
            });

            document.querySelectorAll('.mobile-nav-tab').forEach(tab => {
                tab.addEventListener('click', () => showView(tab.dataset.view));
            });

            // User dropdown
            document.getElementById('userMenuBtn').addEventListener('click', () => {
                document.getElementById('userDropdown').classList.toggle('hidden');
            });

            document.addEventListener('click', (e) => {
                if (!e.target.closest('#userMenuBtn') && !e.target.closest('#userDropdown')) {
                    document.getElementById('userDropdown').classList.add('hidden');
                }
            });

            // Project modal
            document.getElementById('addProjectBtn').addEventListener('click', async () => { await openProjectModal(); });
            document.getElementById('projectForm').addEventListener('submit', handleProjectSubmit);

            // Task modal
            document.getElementById('addTaskBtn').addEventListener('click', () => openTaskModal());
            document.getElementById('taskForm').addEventListener('submit', handleTaskSubmit);

            // Project detail tabs
            document.querySelectorAll('.project-tab').forEach(tab => {
                tab.addEventListener('click', () => {
                    document.querySelectorAll('.project-tab').forEach(t => {
                        t.classList.remove('active', 'text-primary', 'border-b-2', 'border-primary');
                        t.classList.add('text-gray-400');
                    });
                    tab.classList.add('active', 'text-primary', 'border-b-2', 'border-primary');
                    tab.classList.remove('text-gray-400');

                    document.querySelectorAll('.project-tab-content').forEach(c => c.classList.add('hidden'));
                    document.getElementById(`project${tab.dataset.projectTab.charAt(0).toUpperCase() + tab.dataset.projectTab.slice(1)}Tab`).classList.remove('hidden');
                });
            });

            // Filters
            document.getElementById('projectFilter').addEventListener('change', renderProjects);
            document.getElementById('categoryFilter').addEventListener('change', renderProjects);
            document.getElementById('taskProjectFilter').addEventListener('change', renderTasks);
            document.getElementById('taskStatusFilter').addEventListener('change', renderTasks);
            document.getElementById('taskPriorityFilter').addEventListener('change', renderTasks);
            document.getElementById('detailTaskStatusFilter').addEventListener('change', renderProjectTasks);
            document.getElementById('calendarProjectFilter').addEventListener('change', renderCalendar);

            // Categories
            document.getElementById('manageCategoriesBtn').addEventListener('click', openCategoryModal);

            // Expose category functions to global scope for onclick handlers
            window.openCategoryModal = openCategoryModal;
            window.closeCategoryModal = closeCategoryModal;
            window.createCategory = createCategory;
            window.editCategory = editCategory;
            window.deleteCategory = deleteCategory;

            // Category CRUD functions
            async function loadCategories() {
                const { categories, error } = await SupabaseCategories.loadAll();
                if (error) {
                    console.error('Error loading categories:', error);
                    showToast('Error loading categories', 'error');
                    return [];
                }
                state.categories = categories || [];
                return state.categories;
            }

            // Make globally accessible for inline handlers and cross-scope calls
            window.populateCategorySelects = async function populateCategorySelects(forceReload = false) {
                // Guard: ensure DOM elements exist
                const projectSelect = document.getElementById('projectCategory');
                const filterSelect = document.getElementById('categoryFilter');
                if (!projectSelect || !filterSelect) {
                    console.warn('Category select elements not found in DOM');
                    return;
                }
                
                // Guard: ensure SupabaseCategories is available with proper retry
                if (typeof SupabaseCategories === 'undefined' || !SupabaseCategories.loadAll) {
                    console.warn('SupabaseCategories not available yet, retrying...');
                    let retries = 0;
                    const maxRetries = 20;
                    while ((typeof SupabaseCategories === 'undefined' || !SupabaseCategories.loadAll) && retries < maxRetries) {
                        await new Promise(r => setTimeout(r, 200));
                        retries++;
                    }
                    if (typeof SupabaseCategories === 'undefined' || !SupabaseCategories.loadAll) {
                        console.warn('SupabaseCategories still not available after', retries, 'retries, trying localStorage fallback');
                        // Try localStorage even if SupabaseCategories isn't available
                        const localCategories = localStorage.getItem('pm_categories');
                        if (localCategories) {
                            try {
                                state.categories = JSON.parse(localCategories);
                                console.log('Loaded', state.categories.length, 'categories from localStorage (fallback)');
                            } catch (e) {
                                console.warn('Error parsing localStorage categories:', e);
                                state.categories = [];
                            }
                        }
                    }
                }
                
                // Load from DB if state.categories is empty OR forceReload is true
                // forceReload is used after create/update/delete to ensure fresh data
                if (state.categories.length === 0 || forceReload) {
                    // Try to load from localStorage first as a quick fallback (only if not forceReload)
                    if (!forceReload && state.categories.length === 0) {
                        const localCategories = localStorage.getItem('pm_categories');
                        if (localCategories) {
                            try {
                                state.categories = JSON.parse(localCategories);
                                console.log('Loaded', state.categories.length, 'categories from localStorage');
                            } catch (e) {
                                console.warn('Error parsing localStorage categories:', e);
                                state.categories = [];
                            }
                        }
                    }
                    
                    // If still empty or forceReload, try to load from DB
                    if ((state.categories.length === 0 || forceReload) && SupabaseCategories && SupabaseCategories.loadAll) {
                        console.log('Loading categories from DB (forceReload=' + forceReload + ')...');
                        const { categories, error } = await SupabaseCategories.loadAll();
                        if (error) {
                            console.error('Error loading categories from DB:', error);
                            // Keep localStorage fallback or existing state
                            // If DB fails but we have localStorage, use it
                            if (state.categories.length === 0) {
                                const localCategories = localStorage.getItem('pm_categories');
                                if (localCategories) {
                                    try {
                                        state.categories = JSON.parse(localCategories);
                                        console.log('Using localStorage fallback after DB error');
                                    } catch (e) {
                                        state.categories = [];
                                    }
                                }
                            }
                        } else {
                            state.categories = categories || [];
                            console.log('Loaded', state.categories.length, 'categories from database');
                        }
                    }
                    
                    // Always save to localStorage after loading from DB (if we got data)
                    if (state.categories.length > 0) {
                        try {
                            localStorage.setItem('pm_categories', JSON.stringify(state.categories));
                            console.log('Saved', state.categories.length, 'categories to localStorage');
                        } catch (e) {
                            console.warn('Error saving categories to localStorage:', e);
                        }
                    }
                } else {
                    console.log('Using cached state.categories:', state.categories.length, 'categories');
                }
                
                const cats = state.categories;
                
                // Clear and repopulate project form select
                // Use innerHTML to fully replace options (avoids ghosting issues)
                let projectHTML = '<option value="">No Category</option>';
                cats.forEach(cat => {
                    projectHTML += `<option value="${cat.id}" style="color: ${cat.color}">${cat.name}</option>`;
                });
                projectSelect.innerHTML = projectHTML;
                
                // Clear and repopulate filter select
                // Fully replace innerHTML to avoid duplicate/ghosted options
                let filterHTML = '<option value="all">All Categories</option>';
                cats.forEach(cat => {
                    filterHTML += `<option value="${cat.id}" style="color: ${cat.color}">${cat.name}</option>`;
                });
                filterSelect.innerHTML = filterHTML;
                
                console.log('Category selects populated with', cats.length, 'categories');
            }

            function openCategoryModal() {
                renderCategoriesList();
                document.getElementById('categoryModal').classList.remove('hidden');
            }

            function closeCategoryModal() {
                document.getElementById('categoryModal').classList.add('hidden');
                document.getElementById('newCategoryName').value = '';
                document.getElementById('newCategoryColor').value = '#6366f1';
            }

            async function renderCategoriesList() {
                const list = document.getElementById('categoriesList');
                await loadCategories();
                
                if (state.categories.length === 0) {
                    list.innerHTML = '<p class="text-gray-400 text-sm text-center py-4">No categories yet. Create one above!</p>';
                    return;
                }
                
                list.innerHTML = state.categories.map(cat => `
                    <div class="flex items-center justify-between bg-gray-700/30 rounded-lg px-4 py-3">
                        <div class="flex items-center space-x-3">
                            <div class="w-4 h-4 rounded" style="background-color: ${cat.color}"></div>
                            <span class="text-white font-medium">${cat.name}</span>
                        </div>
                        <div class="flex items-center space-x-2">
                            <button onclick="editCategory('${cat.id}')" class="p-2 hover:bg-gray-600 rounded-lg transition text-gray-400 hover:text-white">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button onclick="deleteCategory('${cat.id}')" class="p-2 hover:bg-gray-600 rounded-lg transition text-gray-400 hover:text-red-400">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                `).join('');
            }

            async function createCategory() {
                const name = document.getElementById('newCategoryName').value.trim();
                const color = document.getElementById('newCategoryColor').value;
                
                if (!name) {
                    showToast('Please enter a category name', 'error');
                    return;
                }
                
                const { data, error } = await SupabaseCategories.create({ name, color });
                if (error) {
                    showToast('Error creating category: ' + error, 'error');
                    return;
                }
                
                showToast('Category created!', 'success');
                document.getElementById('newCategoryName').value = '';
                await populateCategorySelects(true); // forceReload = true to ensure fresh data
                await renderCategoriesList();
            }

            function editCategory(id) {
                const cat = state.categories.find(c => c.id === id);
                if (!cat) return;
                
                const newName = prompt('Edit category name:', cat.name);
                if (newName === null) return;
                
                const newColor = prompt('Edit category color (hex code like #6366f1):', cat.color);
                if (newColor === null) return;
                
                SupabaseCategories.update(id, { 
                    name: newName.trim() || cat.name, 
                    color: newColor || cat.color 
                }).then(async ({ error }) => {
                    if (error) {
                        showToast('Error updating category', 'error');
                        return;
                    }
                    showToast('Category updated!', 'success');
                    await populateCategorySelects(true); // forceReload = true to ensure fresh data
                    await renderCategoriesList();
                });
            }

            async function deleteCategory(id) {
                if (!confirm('Delete this category? Projects with this category will have no category.')) {
                    return;
                }
                
                const { error } = await SupabaseCategories.delete(id);
                if (error) {
                    showToast('Error deleting category', 'error');
                    return;
                }
                
                showToast('Category deleted!', 'success');
                await populateCategorySelects(true); // forceReload = true to ensure fresh data
                await renderCategoriesList();
            }

            // Import/Export
            document.getElementById('exportDataBtn').addEventListener('click', exportAllData);
            document.getElementById('importDataInput').addEventListener('change', (e) => {
                if (e.target.files[0]) {
                    importData(e.target.files[0]);
                }
            });

            // Global search
            document.getElementById('globalSearch').addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    handleGlobalSearch(e.target.value);
                }
            });

            // Initialize file drop zone
            initFileDropZone();

            // Initialize auth and theme - MUST be called after all functions are defined
            initAuth();
            initTheme();
        });
    </script>
</body>
</html>
