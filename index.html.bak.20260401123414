        async function handleTaskSubmit(e) {
            e.preventDefault();

            const id = document.getElementById('taskId').value || generateId();
            const isUpdate = !!document.getElementById('taskId').value;

            // Collect subtasks
            const subtaskItems = document.querySelectorAll('#subtasksContainer .subtask-item');
            const subtasks = Array.from(subtaskItems).map(item => ({
                id: item.dataset.id,
                title: item.querySelector('.subtask-title').value,
                completed: item.querySelector('.subtask-checkbox').checked
            })).filter(s => s.title.trim());

            // Collect comments
            const commentElements = document.querySelectorAll('#taskComments > div');
            const comments = Array.from(commentElements).map(el => ({
                text: el.querySelector('p').textContent,
                timestamp: el.querySelector('.text-gray-400')?.textContent || new Date().toISOString()
            }));

            const taskData = {
                id,
                project_id: document.getElementById('taskProjectId').value,
                title: document.getElementById('taskTitle').value,
                description: document.getElementById('taskDescription').value,
                status: document.getElementById('taskStatus').value,
                priority: document.getElementById('taskPriority').value,
                assignee: document.getElementById('taskAssignee').value,
                dueDate: document.getElementById('taskDueDate').value,
                subtasks,
                comments,
                userId: state.currentUser.id,
                createdAt: new Date().toISOString(),
                updatedAt: new Date().toISOString()
            };

            if (isUpdate) {
                // Update existing
                const index = state.tasks.findIndex(t => t.id === id);
                if (index !== -1) {
                    taskData.createdAt = state.tasks[index].createdAt;
                    state.tasks[index] = taskData;
                    logActivity('task_updated', id, `Updated task "${taskData.title}"`);
                    showToast('Task updated successfully', 'success');
                }
                // CRITICAL FIX: Persist to Supabase database
                if (typeof SupabaseDB !== 'undefined' && SupabaseDB.updateTask) {
                    const dbResult = await SupabaseDB.updateTask(id, {
                        title: taskData.title,
                        description: taskData.description,
                        status: taskData.status,
                        priority: taskData.priority,
                        assignee: taskData.assignee,
                        dueDate: taskData.dueDate,
                        subtasks: taskData.subtasks,
                        comments: taskData.comments
                    });
                    if (dbResult && dbResult.error) {
                        console.error('Failed to persist task update to DB:', dbResult.error);
                    } else {
                        console.log('Task update persisted to Supabase:', id);
                    }
                }
            } else {
                // Create new
                state.tasks.unshift(taskData);
                logActivity('task_created', id, `Created task "${taskData.title}"`);
                showToast('Task created successfully', 'success');
                // CRITICAL FIX: Persist to Supabase database
                if (typeof SupabaseDB !== 'undefined' && SupabaseDB.saveTask) {
                    const dbResult = await SupabaseDB.saveTask(taskData);
                    if (dbResult && dbResult.error) {
                        console.error('Failed to persist new task to DB:', dbResult.error);
                    } else {
                        console.log('New task persisted to Supabase:', id);
                    }
                }
            }

            saveToLocalStorage();
            closeTaskModal();

            if (state.currentView === 'tasks') {
                renderTasks();
            } else if (state.currentView === 'project-detail') {
                renderProjectTasks();
                updateProjectStats();
            }
            updateStats();
        }

        function openTaskDetail(taskId) {
            state.currentTaskId = taskId;
            const task = state.tasks.find(t => t.id === taskId);
            if (!task) return;

            const project = state.projects.find(p => p.id === task.project_id);

            document.getElementById('taskDetailTitle').textContent = task.title;
            document.getElementById('taskDetailStatus').outerHTML = getStatusBadge(task.status).replace('class="', 'id="taskDetailStatus" class="');
            document.getElementById('taskDetailPriority').outerHTML = getPriorityBadge(task.priority).replace('class="', 'id="taskDetailPriority" class="');
            document.getElementById('taskDetailProject').innerHTML = `<span class="px-3 py-1 rounded-full text-xs font-medium" style="background-color: ${project?.color || '#4f46e5'}20; color: ${project?.color || '#4f46e5'}">${project?.name || 'No Project'}</span>`;
            document.getElementById('taskDetailAssignee').textContent = task.assignee || 'Unassigned';
            document.getElementById('taskDetailDueDate').textContent = formatDate(task.dueDate);
            document.getElementById('taskDetailCreated').textContent = formatDateTime(task.createdAt);
            document.getElementById('taskDetailDescription').textContent = task.description || 'No description provided.';

            // Render subtasks
            const subtasksContainer = document.getElementById('taskDetailSubtasks');
            if (task.subtasks && task.subtasks.length > 0) {
                subtasksContainer.innerHTML = task.subtasks.map(subtask => `
                    <label class="flex items-center space-x-3 p-2 hover:bg-gray-700/30 rounded-lg cursor-pointer">
                        <input type="checkbox" ${subtask.completed ? 'checked' : ''}
                               onchange="toggleSubtask('${task.id}', '${subtask.id}')"
                               class="custom-checkbox">
                        <span class="${subtask.completed ? 'line-through text-gray-500' : ''}">${subtask.title}</span>
                    </label>
                `).join('');
            } else {
                subtasksContainer.innerHTML = '<p class="text-gray-400 text-sm">No subtasks</p>';
            }

            // Render comments
            const commentsContainer = document.getElementById('taskDetailComments');
            if (task.comments && task.comments.length > 0) {
                commentsContainer.innerHTML = task.comments.map(comment => `
                    <div class="bg-gray-700/50 rounded-lg p-3">
                        <p class="text-sm">${comment.text}</p>
                        <p class="text-xs text-gray-400 mt-1">${formatDateTime(comment.timestamp)}</p>
                    </div>
                `).join('');
            } else {
                commentsContainer.innerHTML = '<p class="text-gray-400 text-sm">No comments yet</p>';
            }

            // Initialize task file drop zone and render task files
            initTaskDetailFileDropZone(taskId);
            renderTaskDetailFiles(taskId);

