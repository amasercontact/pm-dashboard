<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProjectFlow - Project Management Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css">
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
    <style>
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #1f2937;
        }
        ::-webkit-scrollbar-thumb {
            background: #4b5563;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #6b7280;
        }

        /* FullCalendar Customizations */
        .dark .fc {
            background-color: #1f2937;
            border-radius: 0.5rem;
        }
        .dark .fc-theme-standard td,
        .dark .fc-theme-standard th {
            border-color: #374151;
        }
        .dark .fc-theme-standard .fc-scrollgrid {
            border-color: #374151;
        }
        .dark .fc-daygrid-day {
            background-color: #1f2937;
        }
        .dark .fc-daygrid-day:hover {
            background-color: #374151;
        }
        .dark .fc-daygrid-day-number {
            color: #9ca3af;
        }
        .dark .fc-col-header-cell-cushion {
            color: #d1d5db;
        }
        .dark .fc-event {
            border-radius: 4px;
            padding: 2px 4px;
            font-size: 0.75rem;
        }
        .dark .fc-toolbar-title {
            color: #f3f4f6 !important;
        }
        .dark .fc-button-primary {
            background-color: #4f46e5 !important;
            border-color: #4f46e5 !important;
        }
        .dark .fc-button-primary:hover {
            background-color: #4338ca !important;
        }
        .fc-day-today {
            background-color: rgba(79, 70, 229, 0.2) !important;
        }

        /* Priority Colors */
        .priority-critical { border-left: 4px solid #ef4444; }
        .priority-high { border-left: 4px solid #f97316; }
        .priority-medium { border-left: 4px solid #eab308; }
        .priority-low { border-left: 4px solid #22c55e; }

        /* Status Badges */
        .status-active { background-color: #22c55e; }
        .status-on-hold { background-color: #f97316; }
        .status-completed { background-color: #6b7280; }
        .status-cancelled { background-color: #ef4444; }

        /* Animations */
        @keyframes slideIn {
            from { transform: translateX(-100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        @keyframes scaleIn {
            from { transform: scale(0.9); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
        .animate-slideIn { animation: slideIn 0.3s ease-out; }
        .animate-fadeIn { animation: fadeIn 0.3s ease-out; }
        .animate-scaleIn { animation: scaleIn 0.2s ease-out; }

        /* Drop Zone */
        .drop-zone {
            border: 2px dashed #4b5563;
            transition: all 0.3s ease;
        }
        .drop-zone.dragover {
            border-color: #4f46e5;
            background-color: rgba(79, 70, 229, 0.1);
        }

        /* Custom checkbox */
        .custom-checkbox {
            appearance: none;
            width: 1.25rem;
            height: 1.25rem;
            border: 2px solid #4b5563;
            border-radius: 4px;
            cursor: pointer;
            position: relative;
        }
        .custom-checkbox:checked {
            background-color: #4f46e5;
            border-color: #4f46e5;
        }
        .custom-checkbox:checked::after {
            content: '✓';
            position: absolute;
            color: white;
            font-size: 0.75rem;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        /* Kanban Column */
        .kanban-column {
            min-height: 400px;
            max-height: calc(100vh - 300px);
            overflow-y: auto;
        }

        /* Mobile Menu */
        .mobile-menu {
            transform: translateX(-100%);
            transition: transform 0.3s ease;
        }
        .mobile-menu.open {
            transform: translateX(0);
        }

        /* Toast Notification */
        .toast {
            animation: slideIn 0.3s ease-out;
        }

        /* Project Card Hover */
        .project-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .project-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
        }

        /* Task Item */
        .task-item {
            transition: background-color 0.2s ease;
        }
        .task-item:hover {
            background-color: rgba(79, 70, 229, 0.1);
        }

        /* Modal Backdrop */
        .modal-backdrop {
            backdrop-filter: blur(4px);
        }

        /* Light mode overrides */
        .light .fc-theme-standard td,
        .light .fc-theme-standard th {
            border-color: #e5e7eb;
        }
        .light .fc-theme-standard .fc-scrollgrid {
            border-color: #e5e7eb;
        }
        .light .fc-daygrid-day {
            background-color: #ffffff;
        }
        .light .fc-daygrid-day:hover {
            background-color: #f3f4f6;
        }
        .light .fc-daygrid-day-number {
            color: #374151;
        }
        .light .fc-col-header-cell-cushion {
            color: #111827;
        }
        .light .fc-toolbar-title {
            color: #111827 !important;
        }
        .light ::-webkit-scrollbar-track {
            background: #f3f4f6;
        }
        .light ::-webkit-scrollbar-thumb {
            background: #d1d5db;
        }
    </style>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#4f46e5',
                        secondary: '#10b981',
                        danger: '#ef4444',
                        warning: '#f59e0b',
                        info: '#3b82f6'
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-900 text-gray-100 dark:bg-gray-900 dark:text-gray-100 min-h-screen">
    <!-- Login Screen -->
    <div id="loginScreen" class="min-h-screen flex items-center justify-center p-4 bg-gradient-to-br from-gray-900 via-purple-900 to-gray-900">
        <div class="w-full max-w-md">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary/20 mb-4">
                    <i class="fas fa-project-diagram text-3xl text-primary"></i>
                </div>
                <h1 class="text-4xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-purple-400 to-pink-400">ProjectFlow</h1>
                <p class="text-gray-400 mt-2">Modern Project Management</p>
            </div>

            <div class="bg-gray-800/50 backdrop-blur-xl rounded-2xl p-8 shadow-2xl border border-gray-700">
                <h2 class="text-2xl font-bold mb-6 text-center" id="authTitle">Sign In</h2>

                <form id="authForm" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Email Address</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                                <i class="fas fa-envelope"></i>
                            </span>
                            <input type="email" id="authEmail" required
                                class="w-full bg-gray-700/50 border border-gray-600 rounded-lg pl-10 pr-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
                                placeholder="you@example.com">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Password</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input type="password" id="authPassword" required
                                class="w-full bg-gray-700/50 border border-gray-600 rounded-lg pl-10 pr-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
                                placeholder="••••••••">
                        </div>
                    </div>

                    <div id="confirmPasswordGroup" class="hidden">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Confirm Password</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input type="password" id="authConfirmPassword"
                                class="w-full bg-gray-700/50 border border-gray-600 rounded-lg pl-10 pr-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
                                placeholder="••••••••">
                        </div>
                    </div>

                    <div id="usernameGroup" class="hidden">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Display Name</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                                <i class="fas fa-user"></i>
                            </span>
                            <input type="text" id="authName"
                                class="w-full bg-gray-700/50 border border-gray-600 rounded-lg pl-10 pr-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
                                placeholder="John Doe">
                        </div>
                    </div>

                    <button type="submit" id="authSubmitBtn"
                        class="w-full bg-gradient-to-r from-primary to-purple-600 text-white font-semibold py-3 rounded-lg hover:from-purple-600 hover:to-primary transition-all duration-300 transform hover:scale-[1.02] shadow-lg">
                        Sign In
                    </button>
                </form>

                <div class="mt-6 text-center">
                    <p class="text-gray-400">
                        <span id="toggleAuthText">Don't have an account?</span>
                        <button id="toggleAuthBtn" class="text-primary hover:underline font-medium ml-1">Sign Up</button>
                    </p>
                </div>

                <div class="mt-6 pt-6 border-t border-gray-700">
                    <p class="text-xs text-gray-500 text-center">
                        Demo Mode: Enter any email/password (min 6 chars) to test locally
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Dashboard -->
    <div id="mainDashboard" class="hidden">
        <!-- Header -->
        <header class="bg-gray-800/80 backdrop-blur-xl sticky top-0 z-40 border-b border-gray-700">
            <div class="container mx-auto px-4 py-3">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-4">
                        <!-- Mobile Menu Toggle -->
                        <button id="mobileMenuBtn" class="lg:hidden p-2 hover:bg-gray-700 rounded-lg transition">
                            <i class="fas fa-bars text-xl"></i>
                        </button>

                        <!-- Logo -->
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 rounded-lg bg-primary/20 flex items-center justify-center">
                                <i class="fas fa-project-diagram text-xl text-primary"></i>
                            </div>
                            <span class="text-xl font-bold hidden sm:block">ProjectFlow</span>
                        </div>

                        <!-- Navigation Tabs -->
                        <nav class="hidden lg:flex items-center space-x-1 ml-8">
                            <button data-view="projects" class="nav-tab active px-4 py-2 rounded-lg font-medium transition flex items-center space-x-2">
                                <i class="fas fa-folder"></i>
                                <span>Projects</span>
                            </button>
                            <button data-view="tasks" class="nav-tab px-4 py-2 rounded-lg font-medium transition flex items-center space-x-2">
                                <i class="fas fa-tasks"></i>
                                <span>Tasks</span>
                            </button>
                            <button data-view="calendar" class="nav-tab px-4 py-2 rounded-lg font-medium transition flex items-center space-x-2">
                                <i class="fas fa-calendar"></i>
                                <span>Calendar</span>
                            </button>
                            <button data-view="dashboard" class="nav-tab px-4 py-2 rounded-lg font-medium transition flex items-center space-x-2">
                                <i class="fas fa-chart-pie"></i>
                                <span>Dashboard</span>
                            </button>
                        </nav>
                    </div>

                    <div class="flex items-center space-x-3">
                        <!-- Search -->
                        <div class="relative hidden md:block">
                            <input type="text" id="globalSearch" placeholder="Search..."
                                class="w-64 bg-gray-700/50 border border-gray-600 rounded-lg pl-10 pr-4 py-2 text-sm text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                            <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        </div>

                        <!-- Notifications -->
                        <button class="relative p-2 hover:bg-gray-700 rounded-lg transition">
                            <i class="fas fa-bell text-gray-400"></i>
                            <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
                        </button>

                        <!-- Dark Mode Toggle -->
                        <button id="themeToggle" class="p-2 hover:bg-gray-700 rounded-lg transition">
                            <i class="fas fa-moon text-gray-400 dark-icon"></i>
                            <i class="fas fa-sun text-yellow-400 light-icon hidden"></i>
                        </button>

                        <!-- User Menu -->
                        <div class="relative">
                            <button id="userMenuBtn" class="flex items-center space-x-3 p-2 hover:bg-gray-700 rounded-lg transition">
                                <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center">
                                    <span id="userAvatar" class="text-sm font-bold">U</span>
                                </div>
                                <span id="userName" class="hidden sm:block font-medium">User</span>
                                <i class="fas fa-chevron-down text-xs text-gray-400"></i>
                            </button>

                            <div id="userDropdown" class="hidden absolute right-0 mt-2 w-56 bg-gray-800 border border-gray-700 rounded-xl shadow-2xl py-2 animate-scaleIn">
                                <div class="px-4 py-3 border-b border-gray-700">
                                    <p id="dropdownUserName" class="font-medium">User Name</p>
                                    <p id="dropdownUserEmail" class="text-sm text-gray-400">user@example.com</p>
                                </div>
                                <div class="py-2">
                                    <button class="w-full px-4 py-2 text-left hover:bg-gray-700 transition flex items-center space-x-3">
                                        <i class="fas fa-user-circle text-gray-400"></i>
                                        <span>Profile</span>
                                    </button>
                                    <button class="w-full px-4 py-2 text-left hover:bg-gray-700 transition flex items-center space-x-3">
                                        <i class="fas fa-cog text-gray-400"></i>
                                        <span>Settings</span>
                                    </button>
                                    <button id="exportDataBtn" class="w-full px-4 py-2 text-left hover:bg-gray-700 transition flex items-center space-x-3">
                                        <i class="fas fa-download text-gray-400"></i>
                                        <span>Export Data</span>
                                    </button>
                                    <label class="w-full px-4 py-2 text-left hover:bg-gray-700 transition flex items-center space-x-3 cursor-pointer">
                                        <i class="fas fa-upload text-gray-400"></i>
                                        <span>Import Data</span>
                                        <input type="file" id="importDataInput" accept=".json" class="hidden">
                                    </label>
                                </div>
                                <div class="pt-2 border-t border-gray-700">
                                    <button id="logoutBtn" class="w-full px-4 py-2 text-left hover:bg-gray-700 transition flex items-center space-x-3 text-red-400">
                                        <i class="fas fa-sign-out-alt"></i>
                                        <span>Logout</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Mobile Navigation Overlay -->
        <div id="mobileNavOverlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden"></div>

        <!-- Mobile Navigation -->
        <nav id="mobileNav" class="mobile-menu fixed left-0 top-0 h-full w-72 bg-gray-800 z-50 lg:hidden">
            <div class="p-4 border-b border-gray-700">
                <div class="flex items-center justify-between">
                    <span class="text-lg font-bold">Menu</span>
                    <button id="closeMobileNav" class="p-2 hover:bg-gray-700 rounded-lg">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
            <div class="p-4 space-y-2">
                <button data-view="projects" class="mobile-nav-tab w-full px-4 py-3 rounded-lg text-left hover:bg-gray-700 transition flex items-center space-x-3">
                    <i class="fas fa-folder w-6"></i>
                    <span>Projects</span>
                </button>
                <button data-view="tasks" class="mobile-nav-tab w-full px-4 py-3 rounded-lg text-left hover:bg-gray-700 transition flex items-center space-x-3">
                    <i class="fas fa-tasks w-6"></i>
                    <span>Tasks</span>
                </button>
                <button data-view="calendar" class="mobile-nav-tab w-full px-4 py-3 rounded-lg text-left hover:bg-gray-700 transition flex items-center space-x-3">
                    <i class="fas fa-calendar w-6"></i>
                    <span>Calendar</span>
                </button>
                <button data-view="dashboard" class="mobile-nav-tab w-full px-4 py-3 rounded-lg text-left hover:bg-gray-700 transition flex items-center space-x-3">
                    <i class="fas fa-chart-pie w-6"></i>
                    <span>Dashboard</span>
                </button>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="container mx-auto px-4 py-6">
            <!-- Projects View -->
            <section id="projectsView" class="view-section">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
                    <div>
                        <h1 class="text-2xl font-bold">Projects</h1>
                        <p class="text-gray-400 mt-1">Manage your projects and track progress</p>
                    </div>
                    <div class="flex items-center space-x-3">
                        <select id="projectFilter" class="bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
                            <option value="all">All Projects</option>
                            <option value="active">Active</option>
                            <option value="on-hold">On Hold</option>
                            <option value="completed">Completed</option>
                        </select>
                        <select id="categoryFilter" class="bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
                            <option value="all">All Categories</option>
                        </select>
                        <button id="manageCategoriesBtn" class="bg-gray-600 hover:bg-gray-500 text-white font-medium px-3 py-2 rounded-lg transition flex items-center space-x-2" title="Manage Categories">
                            <i class="fas fa-tags"></i>
                        </button>
                        <button id="addProjectBtn" class="bg-primary hover:bg-primary/80 text-white font-medium px-4 py-2 rounded-lg transition flex items-center space-x-2">
                            <i class="fas fa-plus"></i>
                            <span>New Project</span>
                        </button>
                    </div>
                </div>

                <!-- Projects Grid -->
                <div id="projectsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                    <!-- Project cards will be rendered here -->
                </div>

                <!-- Empty State -->
                <div id="projectsEmptyState" class="hidden text-center py-16">
                    <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gray-800 flex items-center justify-center">
                        <i class="fas fa-folder-plus text-4xl text-gray-600"></i>
                    </div>
                    <h3 class="text-xl font-semibold mb-2">No projects yet</h3>
                    <p class="text-gray-400 mb-6">Create your first project to get started</p>
                    <button onclick="openProjectModal()" class="bg-primary hover:bg-primary/80 text-white font-medium px-6 py-3 rounded-lg transition">
                        <i class="fas fa-plus mr-2"></i>Create Project
                    </button>
                </div>
            </section>

            <!-- Tasks View -->
            <section id="tasksView" class="view-section hidden">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
                    <div>
                        <h1 class="text-2xl font-bold">Tasks</h1>
                        <p class="text-gray-400 mt-1">View and manage all your tasks</p>
                    </div>
                    <div class="flex items-center space-x-3 flex-wrap">
                        <select id="taskProjectFilter" class="bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
                            <option value="all">All Projects</option>
                        </select>
                        <select id="taskStatusFilter" class="bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
                            <option value="all">All Status</option>
                            <option value="todo">To Do</option>
                            <option value="in-progress">In Progress</option>
                            <option value="review">Review</option>
                            <option value="done">Done</option>
                        </select>
                        <select id="taskPriorityFilter" class="bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
                            <option value="all">All Priority</option>
                            <option value="critical">Critical</option>
                            <option value="high">High</option>
                            <option value="medium">Medium</option>
                            <option value="low">Low</option>
                        </select>
                        <button id="addTaskBtn" class="bg-primary hover:bg-primary/80 text-white font-medium px-4 py-2 rounded-lg transition flex items-center space-x-2">
                            <i class="fas fa-plus"></i>
                            <span>New Task</span>
                        </button>
                    </div>
                </div>

                <!-- Tasks List -->
                <div id="tasksContainer" class="space-y-4">
                    <!-- Tasks will be rendered here -->
                </div>

                <!-- Empty State -->
                <div id="tasksEmptyState" class="hidden text-center py-16">
                    <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gray-800 flex items-center justify-center">
                        <i class="fas fa-tasks text-4xl text-gray-600"></i>
                    </div>
                    <h3 class="text-xl font-semibold mb-2">No tasks yet</h3>
                    <p class="text-gray-400 mb-6">Create your first task to get started</p>
                    <button onclick="openTaskModal()" class="bg-primary hover:bg-primary/80 text-white font-medium px-6 py-3 rounded-lg transition">
                        <i class="fas fa-plus mr-2"></i>Create Task
                    </button>
                </div>
            </section>

            <!-- Calendar View -->
            <section id="calendarView" class="view-section hidden">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
                    <div>
                        <h1 class="text-2xl font-bold">Calendar</h1>
                        <p class="text-gray-400 mt-1">View tasks and deadlines on a calendar</p>
                    </div>
                    <div class="flex items-center space-x-3">
                        <select id="calendarProjectFilter" class="bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
                            <option value="all">All Projects</option>
                        </select>
                    </div>
                </div>

                <div class="bg-gray-800/50 rounded-xl p-4 md:p-6 border border-gray-700">
                    <div id="calendar"></div>
                </div>
            </section>

            <!-- Dashboard View -->
            <section id="dashboardView" class="view-section hidden">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h1 class="text-2xl font-bold">Dashboard</h1>
                        <p class="text-gray-400 mt-1">Overview of your project management</p>
                    </div>
